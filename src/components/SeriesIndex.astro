---
import { entryLink, formatDate, getPublishedSeriesEntries } from '../lib/docs';

const { seriesName } = Astro.props;
const entries = await getPublishedSeriesEntries(seriesName);
---

<section class="series-index">
  <h1>{seriesName}</h1>

  <p>Below are the published entries in this series.</p>

  {entries.length > 0 ? (
    <ul>
      {entries.map((entry) => (
        <li>
          {entry.data.seriesOrder != null && (
            <span class="series-order">Part {entry.data.seriesOrder}: </span>
          )}
          <a href={entryLink(entry.id, import.meta.env.BASE_URL)}>{entry.data.title ?? entry.id}</a>
          {entry.data.date && (
            <span class="series-date"> — {formatDate(entry.data.date)}</span>
          )}
        </li>
      ))}
    </ul>
  ) : (
    <p>No published entries were found for this series yet.</p>
  )}
</section>
