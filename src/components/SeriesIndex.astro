---
import { getCollection } from 'astro:content';

const { seriesName } = Astro.props;
const entries = await getCollection('docs', (entry) =>
  entry.data.series === seriesName && entry.data.status !== 'draft'
);

const sermons = [...entries].sort((a, b) => {
  const aOrder = a.data.seriesOrder ?? 0;
  const bOrder = b.data.seriesOrder ?? 0;
  return aOrder - bOrder || a.data.title.localeCompare(b.data.title);
});

const formatDate = (date: Date | string | undefined): string => {
  if (!date) return '';
  const d = typeof date === 'string' ? new Date(date) : date;
  const day = d.getDate().toString().padStart(2, '0');
  const month = d.toLocaleDateString('en-US', { month: 'short' });
  const year = d.getFullYear();
  return `${day} ${month} ${year}`;
};

const pageLink = (id: string) => `/${id.replace(/\.mdx?$/, '')}`;
---

<section class="series-index">
  <h1>{seriesName}</h1>

  <p>Below are the sermons in this series.</p>

  {sermons.length > 0 ? (
    <ul>
      {sermons.map((entry) => (
        <li>
          {entry.data.seriesOrder != null && (
            <span class="series-order">Part {entry.data.seriesOrder}: </span>
          )}
          <a href={pageLink(entry.id)}>{entry.data.title ?? entry.id}</a>
          {entry.data.date && (
            <span class="series-date"> — {formatDate(entry.data.date)}</span>
          )}
        </li>
      ))}
    </ul>
  ) : (
    <p>No published sermons were found for this series yet.</p>
  )}
</section>
