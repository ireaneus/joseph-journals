---
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import SidebarSublist from '@astrojs/starlight/components/SidebarSublist.astro';
import { Icon } from '@astrojs/starlight/components';
import type { StarlightRouteData } from '@astrojs/starlight/route-data';
import type { StarlightIcon } from '@astrojs/starlight/types';

const { sidebar } = Astro.locals.starlightRoute;

type SidebarEntry = StarlightRouteData['sidebar'][number];
type SidebarLink = Extract<SidebarEntry, { type: 'link' }>;

const firstLink = (entries: SidebarEntry[]): SidebarLink | undefined => {
	for (const entry of entries) {
		if (entry.type === 'link') return entry;
		const nestedLink = firstLink(entry.entries);
		if (nestedLink) return nestedLink;
	}
};

const iconForLabel = (label: string): StarlightIcon => {
	const normalized = label.toLowerCase();
	if (normalized.includes('home')) return 'starlight';
	if (normalized.includes('bio')) return 'heart';
	if (normalized.includes('article')) return 'document';
	if (normalized.includes('devotion')) return 'open-book';
	if (normalized.includes('bible')) return 'list-format';
	if (normalized.includes('resource')) return 'star';
	return 'document';
};

const railItems = sidebar.map((entry) => {
	const nestedLink = entry.type === 'group' ? firstLink(entry.entries) : undefined;
	return {
		type: entry.type,
		label: entry.label,
		icon: iconForLabel(entry.label),
		href: entry.type === 'link' ? entry.href : nestedLink?.href,
		isCurrent:
			entry.type === 'link'
				? entry.isCurrent
				: entry.entries.some((item) =>
						item.type === 'link' ? item.isCurrent : firstLink(item.entries)?.isCurrent
					),
	};
});
---

<script is:inline>
	(() => {
		try {
			if (localStorage.getItem('jj-sidebar-collapsed') === 'true') {
				document.documentElement.dataset.sidebarCollapsed = 'true';
			}
		} catch {}
	})();
</script>

<div class="sidebar-expanded">
	<button
		type="button"
		class="sidebar-collapse-toggle jj-sidebar-toggle"
		aria-pressed="false"
		aria-label="Collapse sidebar"
		title="Collapse sidebar"
	>
		<Icon name="left-arrow" size="1rem" />
		<span>Collapse</span>
	</button>

	<SidebarPersister>
		<SidebarSublist sublist={sidebar} />
	</SidebarPersister>
</div>

<nav class="sidebar-icon-rail" aria-label="Collapsed sidebar navigation">
	<button
		type="button"
		class="sidebar-rail-button sidebar-rail-toggle jj-sidebar-toggle"
		aria-pressed="true"
		aria-label="Expand sidebar"
		title="Expand sidebar"
	>
		<Icon name="right-arrow" size="1.15rem" />
		<span class="sidebar-tooltip" role="tooltip">Expand sidebar</span>
	</button>

	<ul>
		{
			railItems.map((item) => (
				<li>
					{item.type === 'group' ? (
						<button
							type="button"
							class:list={['sidebar-rail-link', 'sidebar-rail-group', { 'is-current': item.isCurrent }]}
							aria-label={`Expand ${item.label}`}
							data-sidebar-group={item.label}
						>
							<Icon name={item.icon} size="1.15rem" />
							<span class="sidebar-tooltip" role="tooltip">{item.label}</span>
						</button>
					) : (
						<a
							href={item.href}
							class:list={['sidebar-rail-link', { 'is-current': item.isCurrent }]}
							aria-label={item.label}
							aria-current={item.isCurrent ? 'page' : undefined}
						>
							<Icon name={item.icon} size="1.15rem" />
							<span class="sidebar-tooltip" role="tooltip">{item.label}</span>
						</a>
					)}
				</li>
			))
		}
	</ul>
</nav>

<div class="md:sl-hidden">
	<MobileMenuFooter />
</div>

<script is:inline>
	(() => {
		const storageKey = 'jj-sidebar-collapsed';
		const root = document.documentElement;
		const query = matchMedia('(min-width: 50rem)');

		const setCollapsed = (collapsed) => {
			if (!query.matches) {
				delete root.dataset.sidebarCollapsed;
				return;
			}

			if (collapsed) root.dataset.sidebarCollapsed = 'true';
			else delete root.dataset.sidebarCollapsed;

			try {
				localStorage.setItem(storageKey, collapsed ? 'true' : 'false');
			} catch {}

			document.querySelectorAll('.jj-sidebar-toggle').forEach((button) => {
				button.setAttribute('aria-pressed', String(collapsed));
			});
		};

		document.querySelectorAll('.jj-sidebar-toggle').forEach((button) => {
			button.addEventListener('click', () => {
				setCollapsed(root.dataset.sidebarCollapsed !== 'true');
			});
		});

		document.querySelectorAll('[data-sidebar-group]').forEach((button) => {
			button.addEventListener('click', () => {
				const label = button.getAttribute('data-sidebar-group');
				setCollapsed(false);
				if (!label) return;

				document.querySelectorAll('.sidebar-expanded details').forEach((details) => {
					const summaryLabel = details.querySelector('summary .large')?.textContent?.trim();
					if (summaryLabel === label) details.open = true;
				});
			});
		});

		query.addEventListener('change', () => {
			const collapsed = (() => {
				try {
					return localStorage.getItem(storageKey) === 'true';
				} catch {
					return false;
				}
			})();
			setCollapsed(collapsed);
		});
	})();
</script>

<style>
	@layer starlight.core {
		.sidebar-icon-rail {
			display: none;
		}

		.sidebar-collapse-toggle,
		.sidebar-rail-button,
		.sidebar-rail-link {
			border: 0;
			font: inherit;
			color: var(--sl-color-text);
			background: transparent;
		}

		.sidebar-collapse-toggle {
			display: none;
			align-items: center;
			justify-content: space-between;
			gap: 0.5rem;
			width: 100%;
			margin: 0 0 0.35rem;
			padding: 0.45rem 0.5rem;
			border-radius: 0.375rem;
			color: var(--sl-color-gray-2);
			cursor: pointer;
		}

		.sidebar-collapse-toggle:hover,
		.sidebar-collapse-toggle:focus-visible {
			color: var(--sl-color-text);
			background: var(--sl-color-accent-low);
		}

		@media (min-width: 50rem) {
			.sidebar-collapse-toggle {
				display: flex;
			}

			:global(html[data-sidebar-collapsed='true']) {
				--sl-content-inline-start: 4.75rem;
			}

			:global(html[data-sidebar-collapsed='true'][data-has-sidebar]) :global(.main-frame) {
				padding-inline-start: 4.75rem;
			}

			:global(html[data-sidebar-collapsed='true'][data-has-sidebar]) :global(.main-frame > .lg\:sl-flex) {
				width: calc(100vw - 4.75rem);
				max-width: none;
			}

			:global(html[data-sidebar-collapsed='true'][data-has-sidebar][data-has-toc]) :global(.main-pane) {
				width: calc(100% - var(--sl-sidebar-width));
			}

			:global(html[data-sidebar-collapsed='true'][data-has-sidebar][data-has-toc]) :global(.right-sidebar-container) {
				width: var(--sl-sidebar-width);
			}

			:global(html[data-sidebar-collapsed='true']) :global(.sidebar-pane) {
				width: 4.75rem;
				overflow: visible;
			}

			:global(html[data-sidebar-collapsed='true']) :global(.sidebar-content) {
				padding-inline: 0.55rem;
				overflow: visible;
			}

			:global(html[data-sidebar-collapsed='true'][data-has-sidebar]) :global(.main-pane .sl-container) {
				max-width: min(
					59rem,
					calc(100vw - 4.75rem - var(--sl-sidebar-width) - 2 * var(--sl-content-pad-x))
				);
			}

			:global(html[data-sidebar-collapsed='true']) .sidebar-expanded {
				display: none;
			}

			:global(html[data-sidebar-collapsed='true']) .sidebar-icon-rail {
				display: flex;
				position: relative;
				flex-direction: column;
				align-items: center;
				gap: 0.65rem;
				padding-block: 0.15rem 1rem;
			}

			.sidebar-icon-rail ul {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.45rem;
				width: 100%;
				margin: 0;
				padding: 0;
				list-style: none;
			}

			.sidebar-icon-rail li {
				position: relative;
				width: 100%;
			}

			.sidebar-rail-button,
			.sidebar-rail-link {
				position: relative;
				display: flex;
				align-items: center;
				justify-content: center;
				width: 2.65rem;
				height: 2.65rem;
				margin-inline: auto;
				border-radius: 0.45rem;
				color: var(--sl-color-gray-2);
				text-decoration: none;
				cursor: pointer;
			}

			.sidebar-rail-button:hover,
			.sidebar-rail-button:focus-visible,
			.sidebar-rail-link:hover,
			.sidebar-rail-link:focus-visible,
			.sidebar-rail-link.is-current {
				color: var(--sl-color-text-invert);
				background: var(--sl-color-text-accent);
				outline: none;
			}

			.sidebar-tooltip {
				position: absolute;
				z-index: 10;
				inset-inline-start: calc(100% + 0.75rem);
				top: 50%;
				min-width: max-content;
				max-width: 14rem;
				padding: 0.35rem 0.6rem;
				border: 1px solid var(--sl-color-hairline-shade);
				border-radius: 0.35rem;
				background: var(--sl-color-bg);
				box-shadow: 0 8px 22px rgba(0, 0, 0, 0.16);
				color: var(--sl-color-text);
				font-size: var(--sl-text-sm);
				line-height: 1.2;
				opacity: 0;
				pointer-events: none;
				transform: translateY(-50%) translateX(-0.25rem);
				transition:
					opacity 0.16s ease,
					transform 0.16s ease;
			}

			.sidebar-tooltip::before {
				content: '';
				position: absolute;
				top: 50%;
				inset-inline-start: -0.34rem;
				width: 0.6rem;
				height: 0.6rem;
				border-inline-start: 1px solid var(--sl-color-hairline-shade);
				border-block-end: 1px solid var(--sl-color-hairline-shade);
				background: var(--sl-color-bg);
				transform: translateY(-50%) rotate(45deg);
			}

			.sidebar-rail-button:hover .sidebar-tooltip,
			.sidebar-rail-button:focus-visible .sidebar-tooltip,
			.sidebar-rail-link:hover .sidebar-tooltip,
			.sidebar-rail-link:focus-visible .sidebar-tooltip {
				opacity: 1;
				transform: translateY(-50%) translateX(0);
			}
		}
	}
</style>
