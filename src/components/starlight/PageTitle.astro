---
import { entryLink, getSiblingSeriesEntries, type DocsEntry } from '../../lib/docs';

const { starlightRoute } = Astro.locals;
const currentEntry = starlightRoute.entry as DocsEntry;
const siblingEntries = await getSiblingSeriesEntries(currentEntry);

const currentIndex = siblingEntries.findIndex((entry) => entry.id === currentEntry.id);
const previousEntry = currentIndex > 0 ? siblingEntries[currentIndex - 1] : undefined;
const nextEntry =
  currentIndex >= 0 && currentIndex < siblingEntries.length - 1
    ? siblingEntries[currentIndex + 1]
    : undefined;
---

<h1 id="_top">{currentEntry.data.title}</h1>

{(previousEntry || nextEntry) && (
  <nav class="article-nav-cards" aria-label="Article navigation">
    {previousEntry ? (
      <a class="article-nav-card article-nav-card-prev" href={entryLink(previousEntry.id, import.meta.env.BASE_URL)}>
        <span class="article-nav-eyebrow">Previous</span>
        <span class="article-nav-title">{previousEntry.data.title ?? previousEntry.id}</span>
        {previousEntry.data.passage && (
          <span class="article-nav-meta">{previousEntry.data.passage}</span>
        )}
      </a>
    ) : (
      <div class="article-nav-card article-nav-card-empty" aria-hidden="true"></div>
    )}

    {nextEntry ? (
      <a class="article-nav-card article-nav-card-next" href={entryLink(nextEntry.id, import.meta.env.BASE_URL)}>
        <span class="article-nav-eyebrow">Next</span>
        <span class="article-nav-title">{nextEntry.data.title ?? nextEntry.id}</span>
        {nextEntry.data.passage && (
          <span class="article-nav-meta">{nextEntry.data.passage}</span>
        )}
      </a>
    ) : (
      <div class="article-nav-card article-nav-card-empty" aria-hidden="true"></div>
    )}
  </nav>
)}

<style>
  @layer starlight.core {
    h1 {
      margin: 1.75rem 0 0.9rem;
      font-size: clamp(2rem, 2.5vw, 2.8rem);
      line-height: 1.2;
      font-weight: 400;
      color: var(--sl-color-text);
      background-color: transparent;
    }

    .article-nav-cards {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1.25rem;
    }

    .article-nav-card {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      padding: 1rem 1.1rem;
      border: 1px solid var(--sl-color-hairline);
      border-radius: 0.85rem;
      background:
        linear-gradient(180deg, color-mix(in srgb, var(--sl-color-accent-low) 55%, transparent), transparent),
        var(--sl-color-bg);
      color: var(--sl-color-text);
      text-decoration: none;
      transition:
        transform 0.18s ease,
        border-color 0.18s ease,
        box-shadow 0.18s ease;
    }

    .article-nav-card:hover {
      transform: translateY(-2px);
      border-color: var(--sl-color-accent);
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
    }

    .article-nav-card-next {
      text-align: right;
      align-items: flex-end;
    }

    .article-nav-eyebrow {
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--sl-color-gray-3);
    }

    .article-nav-title {
      font-size: 1.05rem;
      font-weight: 400;
      line-height: 1.3;
      color: var(--sl-color-text);
    }

    .article-nav-meta {
      font-size: 0.92rem;
      color: var(--sl-color-gray-2);
    }

    .article-nav-card-empty {
      visibility: hidden;
    }

    @media (max-width: 720px) {
      .article-nav-cards {
        grid-template-columns: 1fr;
      }

      .article-nav-card-next {
        text-align: left;
        align-items: flex-start;
      }
    }
  }
</style>
