---
interface Props {
  frontmatter: {
    title?: string;
    description?: string;
    date?: Date;
    passage?: string;
    series?: string;
    speaker?: string;
    tags?: string[];
    status?: string;
    [key: string]: any;
  };
}

const { frontmatter } = Astro.props;

// Format date as "DD Month YYYY"
const formatDate = (date: Date | string | undefined): string => {
  if (!date) return '';
  try {
    const d = typeof date === 'string' ? new Date(date) : new Date(date);
    const options: Intl.DateTimeFormatOptions = {
      day: '2-digit',
      month: 'long',
      year: 'numeric'
    };
    return d.toLocaleDateString('en-US', options);
  } catch {
    return String(date);
  }
};
---

<article class="doc-article">
  <div class="doc-header">
    
    {frontmatter.description && (
      <p class="doc-description">{frontmatter.description}</p>
    )}

    <div class="doc-metadata">
      {frontmatter.date && (
        <div class="meta-item">
          <span class="meta-label">Date:</span>
          <span class="meta-value">{formatDate(frontmatter.date)}</span>
        </div>
      )}

      {frontmatter.passage && (
        <div class="meta-item">
          <span class="meta-label">Passage:</span>
          <span class="meta-value">{frontmatter.passage}</span>
        </div>
      )}

      {frontmatter.series && (
        <div class="meta-item">
          <span class="meta-label">Series:</span>
          <span class="meta-value">{frontmatter.series}</span>
        </div>
      )}

      {frontmatter.speaker && (
        <div class="meta-item">
          <span class="meta-label">Speaker:</span>
          <span class="meta-value">{frontmatter.speaker}</span>
        </div>
      )}

      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <div class="meta-item">
          <span class="meta-label">Tags:</span>
          <div class="tags-list">
            {frontmatter.tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      )}

      {frontmatter.status && (
        <div class="meta-item">
          <span class="meta-label">Status:</span>
          <span class={`status status-${frontmatter.status}`}>{frontmatter.status}</span>
        </div>
      )}
    </div>
  </div>

  <div class="doc-content">
    <slot />
  </div>
</article>

<style is:global>
  :is(body, .doc-content) p,
  :is(body, .doc-content) li,
  :is(body, .doc-content) blockquote,
  :is(body, .doc-content) dd {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--sl-color-text, #222);
  }

  .doc-content h1,
  .doc-content h2,
  .doc-content h3,
  .doc-content h4,
  .doc-content h5,
  .doc-content h6,
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 1.75rem 0 0.9rem;
    line-height: 1.2;
  }

  .doc-content h1 {
    font-size: clamp(2rem, 2.5vw, 2.8rem);
  }

  .doc-content h2 {
    font-size: clamp(1.75rem, 2.2vw, 2.3rem);
  }

  .doc-content h3 {
    font-size: clamp(1.45rem, 1.8vw, 1.75rem);
  }

  .doc-content h4,
  .doc-content h5,
  .doc-content h6 {
    font-size: 1.1rem;
  }

  .doc-content a {
    color: var(--sl-color-accent);
    text-decoration: underline;
    transition: color 0.2s ease;
  }

  .doc-content a:hover {
    color: var(--sl-color-accent-high);
  }

  .doc-content strong,
  .doc-content b {
    font-weight: 600;
  }

  .doc-content em,
  .doc-content i {
    font-style: italic;
  }

  .doc-content ul,
  .doc-content ol {
    padding-left: 1.5rem;
    margin: 1rem 0;
  }

  .doc-content blockquote {
    margin: 1.5rem 0;
    padding-left: 1rem;
    border-left: 4px solid var(--sl-color-accent-low);
    color: var(--sl-color-text);
  }

  .doc-content pre,
  .doc-content code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  }

  .doc-content pre {
    background: var(--sl-color-bg-inline-code);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
  }

  .doc-content code {
    background: var(--sl-color-accent-low);
    padding: 0.15rem 0.3rem;
    border-radius: 0.35rem;
  }

  .doc-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .doc-content th,
  .doc-content td {
    border: 1px solid var(--sl-color-hairline);
    padding: 0.75rem 1rem;
  }

  .doc-content th {
    background: var(--sl-color-gray-6);
    text-align: left;
  }
</style>

<style>
  .doc-article {
    margin: 2rem 0;
  }

  .doc-header {
    margin-bottom: 2rem;
  }

  .doc-header h1 {
    margin: 0 0 0.5rem;
    font-size: 2.5rem;
    font-weight: 400;
    color: var(--sl-color-text, inherit);
  }

  .doc-description {
    margin: 0.5rem 0 1.5rem;
    font-size: 1.1rem;
    color: var(--sl-color-gray-2, #666);
    font-style: italic;
  }

  .doc-metadata {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    background-color: var(--sl-color-gray-6, #f5f5f5);
    border-radius: 0.5rem;
    border-left: 4px solid var(--sl-color-accent-dark, #159b8c);
  }

  .meta-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .meta-label {
    font-weight: 600;
    min-width: 80px;
    color: var(--sl-color-gray-1, #333);
  }

  .meta-value {
    color: var(--sl-color-gray-2, #666);
  }

  .tags-list {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background-color: var(--sl-color-accent, #159b8c);
    color: white;
    border-radius: 1rem;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .status {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .status-draft {
    background-color: #fef3c7;
    color: #92400e;
  }

  .status-published {
    background-color: #dcfce7;
    color: #166534;
  }

  .doc-content {
    margin-top: 2rem;
  }
</style>
