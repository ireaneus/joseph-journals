---
/**
 * DocLayout — wraps a documentation page with an optional header image, description,
 * and either a SeriesIndex (when `seriesName` is set) or the page's slot content.
 *
 * Frontmatter can arrive via two paths:
 *   1. The `frontmatter` prop — used when this layout is referenced directly in MDX.
 *   2. `Astro.locals.starlightRoute.entry.data` — used when Starlight resolves the
 *      layout automatically from the content collection.
 */
import SeriesIndex from '../components/SeriesIndex.astro';
import type { DocsEntry } from '../lib/docs';

type FrontmatterData = {
  title?: string;
  description?: string;
  seriesName?: string;
  image?: string | string[];
  [key: string]: unknown;
};

interface Props {
  frontmatter?: FrontmatterData;
}

const { frontmatter: fmProp } = Astro.props as Props;
// Starlight content collection layouts pass data via locals, not via the frontmatter prop
const starlightEntry = (Astro.locals as { starlightRoute?: { entry: DocsEntry } }).starlightRoute?.entry;
const frontmatter: FrontmatterData = fmProp ?? (starlightEntry?.data as FrontmatterData) ?? {};

const imageValue = frontmatter.image;
const rawImagePath = Array.isArray(imageValue)
  ? imageValue[0]
  : typeof imageValue === 'string' ? imageValue : undefined;

const normalizedImagePath = rawImagePath ? rawImagePath.replace(/^\/+/, '') : undefined;
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const imageSrc = normalizedImagePath
  ? `${baseUrl}${normalizedImagePath}`
  : undefined;

---

<article class="doc-article">
  <div class="doc-header">
    {imageSrc && (
      <img
        src={imageSrc}
        alt={frontmatter.title || 'Document image'}
        class="doc-image"
      />
    )}

    {frontmatter.description && (
      <p class="doc-description">{frontmatter.description}</p>
    )}

  </div>

  <div class="doc-content">
    {frontmatter.seriesName ? (
      <SeriesIndex seriesName={frontmatter.seriesName} />
    ) : (
      <slot />
    )}
  </div>
</article>
