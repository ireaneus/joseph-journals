---
import SeriesIndex from '../components/SeriesIndex.astro';

interface Props {
  frontmatter: {
    title?: string;
    description?: string;
    date?: Date | string;
    passage?: string;
    series?: string;
    seriesName?: string;
    speaker?: string;
    tags?: string[];
    status?: string;
    image?: string;
    [key: string]: unknown;
  };
}

const { frontmatter } = Astro.props as Props;

const normalizedImagePath = frontmatter.image
  ? String(frontmatter.image).replace(/^\/+/, '')
  : undefined;
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const imageSrc = normalizedImagePath
  ? `${baseUrl}${normalizedImagePath}`
  : undefined;

const formatDate = (date: Date | string | undefined): string => {
  if (!date) return '';

  const parsedDate = typeof date === 'string' ? new Date(date) : new Date(date);

  if (Number.isNaN(parsedDate.getTime())) {
    return String(date);
  }

  const day = parsedDate.getDate().toString().padStart(2, '0');
  const month = parsedDate.toLocaleDateString('en-US', { month: 'short' });
  const year = parsedDate.getFullYear();
  return `${day} ${month} ${year}`;
};
---

<article class="doc-article">
  <div class="doc-header">
    {imageSrc && (
      <img
        src={imageSrc}
        alt={frontmatter.title || 'Document image'}
        class="doc-image"
      />
    )}

    {frontmatter.description && (
      <p class="doc-description">{frontmatter.description}</p>
    )}

    <div class="doc-metadata">
      {frontmatter.date && (
        <div class="meta-item">
          <span class="meta-label">Date:</span>
          <span class="meta-value">{formatDate(frontmatter.date)}</span>
        </div>
      )}

      {frontmatter.passage && (
        <div class="meta-item">
          <span class="meta-label">Passage:</span>
          <span class="meta-value">{frontmatter.passage}</span>
        </div>
      )}

      {frontmatter.series && (
        <div class="meta-item">
          <span class="meta-label">Series:</span>
          <span class="meta-value">{frontmatter.series}</span>
        </div>
      )}

      {frontmatter.speaker && (
        <div class="meta-item">
          <span class="meta-label">Speaker:</span>
          <span class="meta-value">{frontmatter.speaker}</span>
        </div>
      )}

      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <div class="meta-item">
          <span class="meta-label">Tags:</span>
          <div class="tags-list">
            {frontmatter.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      )}

      {frontmatter.status && (
        <div class="meta-item">
          <span class="meta-label">Status:</span>
          <span class={`status status-${frontmatter.status}`}>{frontmatter.status}</span>
        </div>
      )}
    </div>
  </div>

  <div class="doc-content">
    {frontmatter.seriesName ? (
      <SeriesIndex seriesName={frontmatter.seriesName} />
    ) : (
      <slot />
    )}
  </div>
</article>
